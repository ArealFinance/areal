{
  "name": "areal",
  "version": "0.1.0",
  "private": true,
  "description": "Areal Finance protocol — meta-repo aggregating contracts, dashboard, bots, framework, and docs via submodules",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArealFinance/areal.git"
  },
  "scripts": {
    "install:all": "npm install --prefix dashboard && npm install --prefix bots",
    "contracts:build": "cd contracts && cargo build-sbf",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "dashboard:check": "npm --prefix dashboard run check",
    "dashboard:deploy": "bash scripts/deploy-dashboard.sh",
    "bot:merkle": "npm --prefix bots run merkle:start",
    "bot:rebalancer": "npm --prefix bots run rebalancer:start"
  }
}
